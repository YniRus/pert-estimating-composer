# Настройки acme.sh
ACME_SH_EMAIL='your_email@example.com' # Ваш email для уведомлений Let's Encrypt
DNS_PROVIDER='dns_timeweb' # Провайдер DNS: 'dns_timeweb', 'dns_cf' (Cloudflare) или 'manual' (ручной режим)
ACME_DNS_SLEEP=120 # Задержка в секундах перед проверкой DNS (для Timeweb рекомендуется 120, для Cloudflare можно меньше)

# Настройки для автоматического режима DNS API (зависит от DNS_PROVIDER):
# 1) Если DNS_PROVIDER='dns_timeweb' (кастомный скрипт из dnsapi/)
Timeweb_Token='your_timeweb_api_token'

# 2) Если DNS_PROVIDER='dns_cf' (встроенный в acme.sh)
# CF_Token='your_cloudflare_api_token'
# CF_Account_ID='your_cloudflare_account_id'

# Настройки rclone
RCLONE_REMOTE_NAME='source_name' # Название удаленного хранилища в rclone (см. rclone/README.md)
